# Backend environment template
# For local SQLite:
DATABASE_URL=sqlite+aiosqlite:///./interview_prep.db

# For production PostgreSQL (example):
# DATABASE_URL=postgresql+asyncpg://user:password@postgres-host:5432/interview_db

# Redis URL
REDIS_URL=redis://localhost:6379/0

# LLM provider API keys
OPENAI_API_KEY=replace_with_openai_key
GROQ_API_KEY=replace_with_groq_key

# JWT signing key (must be long and random in production)
SECRET_KEY=replace_with_long_random_secret

# Comma-separated CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
