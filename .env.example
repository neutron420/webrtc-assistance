# Root-level environment template for local docker-compose usage
# Copy values into .env at repository root before running docker-compose.

# Backend runtime
DATABASE_URL=sqlite+aiosqlite:///./interview_prep.db
REDIS_URL=redis://redis:6379/0
OPENAI_API_KEY=replace_with_openai_key
GROQ_API_KEY=replace_with_groq_key
SECRET_KEY=replace_with_long_random_secret
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Frontend build/runtime
NEXT_PUBLIC_API_URL=http://localhost:8000
